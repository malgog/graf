from typing import List, Dict, Optional

def greedy_coloring(adj: List[List[int]]) -> Dict[int, int]:
    """
    Zachłanne kolorowanie grafu.
    adj[v] = lista sąsiadów wierzchołka v
    Zwraca słownik: wierzchołek -> kolor (liczba całkowita)
    """
    n = len(adj)
    colors = {}

    # Można poprawić wynik, sortując wierzchołki np. po stopniu malejąco
    order = sorted(range(n), key=lambda v: len(adj[v]), reverse=True)

    for v in order:
        used = {colors[u] for u in adj[v] if u in colors}
        c = 0
        while c in used:
            c += 1
        colors[v] = c

    return colors


def is_safe(v: int, c: int, colors: List[int], adj: List[List[int]]) -> bool:
    for u in adj[v]:
        if colors[u] == c:
            return False
    return True


def can_color_with_k(adj: List[List[int]], k: int) -> Optional[List[int]]:
    """
    Sprawdza, czy graf da się pokolorować k kolorami.
    Jeśli tak, zwraca jedno poprawne kolorowanie jako listę.
    Jeśli nie, zwraca None.
    """
    n = len(adj)
    colors = [-1] * n

    # Dobry porządek: wierzchołki o największym stopniu wcześniej
    order = sorted(range(n), key=lambda v: len(adj[v]), reverse=True)

    def backtrack(i: int) -> bool:
        if i == n:
            return True

        v = order[i]
        for c in range(k):
            if is_safe(v, c, colors, adj):
                colors[v] = c
                if backtrack(i + 1):
                    return True
                colors[v] = -1
        return False

    if backtrack(0):
        return colors
    return None


def chromatic_number(adj: List[List[int]]) -> int:
    """
    Wyznacza liczbę chromatyczną (dokładnie), ale działa sensownie
    tylko dla małych grafów.
    """
    n = len(adj)
    for k in range(1, n + 1):
        if can_color_with_k(adj, k) is not None:
            return k
    return n


if __name__ == "__main__":
    # Przykład grafu:
    # 0 -- 1 -- 2
    # |  \     /
    # |    \  /
    # 3 ----- 4
    adj = [
        [1, 3, 4],  # 0
        [0, 2, 4],  # 1
        [1, 4],     # 2
        [0, 4],     # 3
        [0, 1, 2, 3] # 4
    ]

    greedy = greedy_coloring(adj)
    print("Zachłanne kolorowanie:", greedy)
    print("Liczba kolorów w zachłannym:", max(greedy.values()) + 1)

    chi = chromatic_number(adj)
    print("Liczba chromatyczna:", chi)
